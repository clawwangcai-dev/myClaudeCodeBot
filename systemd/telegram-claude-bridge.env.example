TELEGRAM_BOT_TOKEN=
BRIDGE_PROVIDER=claude
CLAUDE_BIN=/home/chao/.local/bin/claude
CLAUDE_WORKDIR=/home/chao/projects/safe-repo
CLAUDE_SETTINGS_FILE=/home/chao/.config/telegram-claude-bridge/claude-settings.json
CLAUDE_PERMISSION_MODE=default
CLAUDE_APPROVAL_PERMISSION_MODE=acceptEdits
CLAUDE_ALLOWED_TOOLS=
CLAUDE_DISALLOWED_TOOLS=
CLAUDE_TIMEOUT_SECONDS=300
CLAUDE_STREAMING=true
TELEGRAM_POLL_TIMEOUT=30
TELEGRAM_EDIT_INTERVAL_SECONDS=1.0
SESSION_STORE_PATH=/home/chao/projects/claudeBot/sessions.json
APPROVAL_STORE_PATH=/home/chao/projects/claudeBot/approval_prefs.json
BRIDGE_PATH_PREFIX=/home/chao/.local/bin:/home/linuxbrew/.linuxbrew/bin:/home/linuxbrew/.linuxbrew/sbin:/usr/local/bin:/usr/bin:/bin
STATUS_WEB_ENABLED=true
STATUS_WEB_HOST=127.0.0.1
STATUS_WEB_PORT=8765
STATUS_WEB_TOKEN=
MEDIA_STORE_PATH=/home/chao/projects/claudeBot/.telegram-media
WHISPER_BIN=/home/linuxbrew/.linuxbrew/bin/whisper
WHISPER_MODEL=base
WHISPER_FALLBACK_MODELS=tiny
WHISPER_LANGUAGE=
WHISPER_THREADS=2
CODEX_BIN=/home/linuxbrew/.linuxbrew/bin/codex
CODEX_MODEL=
CODEX_SANDBOX=workspace-write
CODEX_APPROVAL_POLICY=on-request
